// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DATABASE_URL_UNPOOLED")
}

// ============================================================
// USER MODEL
// ============================================================
model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  phone        String?  @unique
  passwordHash String
  profilePictureUrl         String?
  hasSeenProfilePicturePopup Boolean @default(false)
  dateOfBirth  DateTime?
  addressLine  String?
  city         String?
  state        String?
  pinCode      String?
  profileCompleted Boolean @default(false)
  role         Role     @default(USER)
  status       UserStatus @default(ACTIVE)
  memberType   MemberType @default(FREE)
  referralCode String   @unique @default(cuid())
  referredById String?

  // Relations
  referredBy    User?    @relation("UserReferrals", fields: [referredById], references: [id])
  referrals     User[]   @relation("UserReferrals")
  wallet        Wallet?
  investments   Investment[]
  transactions  Transaction[]
  deposits      Deposit[]
  withdrawals   Withdrawal[]
  referralsMade Referral[]   @relation("ReferrerRelation")
  referralsReceived Referral[] @relation("ReferredRelation")
  kyc           KYC?
  notifications Notification[]
  gifts         Gift[]
  giftDeposits  GiftDeposit[]
  assignedTasks OfflineTask[]
  tickets       Ticket[]
  ticketNotifications TicketNotification[]

  // Badges & Rank
  starPerformer       Boolean   @default(false)
  doubleStarPerformer Boolean   @default(false)
  elitePerformer      Boolean   @default(false)
  tlRank              Boolean   @default(false)
  tlRankEarnedAt      DateTime?
  tlShareholder       Boolean   @default(false)
  directorRank        Boolean   @default(false)
  directorRankEarnedAt DateTime?
  directorShareholder Boolean   @default(false)

  // Active Membership Plan
  membershipPlanId String?
  membershipPlan   MembershipPlan? @relation("UserMembershipPlan", fields: [membershipPlanId], references: [id])
  membershipPlanActivatedAt DateTime?
  membershipPlanExpiresAt   DateTime?
  membershipUpgradeRequests MembershipUpgradeRequest[] @relation("UserUpgradeRequests")
  basicMembershipAmount Float @default(0)
  basicMembershipActivatedAt DateTime?
  basicMembershipExpiresAt DateTime?
  lastDailyYieldAt DateTime?

  // User Pay relations
  sentUserPays     UserPayRequest[] @relation("SenderRequests")
  receivedUserPays UserPayRequest[] @relation("ReceiverRequests")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([referralCode])
  @@index([referredById])
  @@index([membershipPlanId])
}

// ============================================================
// ADMIN MODEL
// ============================================================
model Admin {
  id           String @id @default(cuid())
  username     String @unique
  email        String @unique
  passwordHash String
  role         String @default("SUPER_ADMIN")

  // Actions performed by this admin
  approvedDeposits   Deposit[]    @relation("AdminDepositApproval")
  approvedWithdrawals Withdrawal[] @relation("AdminWithdrawalApproval")
  approvedKYCs       KYC[]        @relation("AdminKYCApproval")
  approvedMembershipUpgrades MembershipUpgradeRequest[] @relation("AdminMembershipUpgradeApproval")

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([username])
}

// ============================================================
// INVESTMENT PLAN MODEL
// ============================================================
model InvestmentPlan {
  id          String      @id @default(cuid())
  name        String
  description String
  minAmount   Float
  maxAmount   Float
  roiPercent  Float       // Daily ROI percentage
  durationDays Int
  status      PlanStatus  @default(ACTIVE)
  features    String[]    // Array of feature strings
  color       String      @default("#3B82F6") // UI accent color
  
  investments Investment[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([status])
}

// ============================================================
// INVESTMENT MODEL
// ============================================================
model Investment {
  id        String           @id @default(cuid())
  userId    String
  planId    String
  amount    Float
  status    InvestmentStatus @default(ACTIVE)
  profit    Float            @default(0)
  startDate DateTime         @default(now())
  endDate   DateTime

  user User           @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan InvestmentPlan @relation(fields: [planId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([planId])
  @@index([status])
}

// ============================================================
// WALLET MODEL
// ============================================================
model Wallet {
  id              String @id @default(cuid())
  userId          String @unique
  mainBalance     Float  @default(0)
  depositBalance  Float  @default(0)
  bonusBalance    Float  @default(0)
  referralBalance Float  @default(0)
  rewardBalance   Float  @default(0)
  levelBalance    Float  @default(0)
  shareBalance    Float  @default(0)
  totalEarned     Float  @default(0) // Cumulative lifetime earnings — never decremented on withdrawal

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
}

// ============================================================
// TRANSACTION MODEL
// ============================================================
model Transaction {
  id          String            @id @default(cuid())
  userId      String
  type        TransactionType
  amount      Float
  status      TransactionStatus @default(PENDING)
  reference   String?
  description String?
  walletType  WalletType        @default(MAIN)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([type])
  @@index([status])
  @@index([createdAt])
}

// ============================================================
// DEPOSIT MODEL
// ============================================================
model Deposit {
  id          String        @id @default(cuid())
  userId      String
  amount      Float
  method      DepositMethod
  proofUrl    String?       // Uploaded payment screenshot
  utrNumber   String?       // UTR/transaction reference
  status      DepositStatus @default(PENDING)
  remarks     String?
  approvedById String?

  // Yield fields
  lastYieldAt       DateTime?
  yieldDaysCredited Int           @default(0)

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy Admin? @relation("AdminDepositApproval", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// WITHDRAWAL MODEL
// ============================================================
model Withdrawal {
  id           String           @id @default(cuid())
  userId       String
  amount       Float
  deduction    Float            @default(0.0)
  netAmount    Float            @default(0.0)
  walletType   WalletType       @default(MAIN)
  status       WithdrawalStatus @default(PENDING)
  bankDetails  Json             // { bankName, accountNo, ifsc, accountName }
  upiId        String?
  remarks      String?
  approvedById String?
  processedAt  DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  approvedBy Admin? @relation("AdminWithdrawalApproval", fields: [approvedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// REFERRAL MODEL
// ============================================================
model Referral {
  id          String @id @default(cuid())
  referrerId  String
  referredId  String
  commission  Float  @default(0)
  level       Int    @default(1) // For multi-level referrals

  referrer User @relation("ReferrerRelation", fields: [referrerId], references: [id])
  referred User @relation("ReferredRelation", fields: [referredId], references: [id])

  createdAt DateTime @default(now())

  @@index([referrerId])
  @@index([referredId])
}

// ============================================================
// KYC MODEL
// ============================================================
model KYC {
  id           String    @id @default(cuid())
  userId       String    @unique
  aadhaarUrl   String?
  aadhaarNo    String?
  panUrl       String?
  panNo        String?
  selfieUrl    String?
  status       KYCStatus @default(PENDING)
  remarks      String?
  reviewedById String?
  reviewedAt   DateTime?

  user       User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  reviewedBy Admin? @relation("AdminKYCApproval", fields: [reviewedById], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
}

// ============================================================
// NOTIFICATION MODEL
// ============================================================
model Notification {
  id      String           @id @default(cuid())
  userId  String
  title   String
  message String
  type    NotificationType @default(INFO)
  isRead  Boolean          @default(false)
  link    String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([isRead])
}

// ============================================================
// ENUMS
// ============================================================
enum Role {
  USER
  ADMIN
}

enum MemberType {
  FREE
  BASIC
  PREMIUM
}

enum UserStatus {
  ACTIVE
  SUSPENDED
  PENDING
}

enum PlanStatus {
  ACTIVE
  INACTIVE
}

enum InvestmentStatus {
  ACTIVE
  COMPLETED
  CANCELLED
}

enum TransactionType {
  DEPOSIT
  WITHDRAWAL
  INVESTMENT
  PROFIT
  REFERRAL_BONUS
  BONUS
  LEVEL_INCOME
  REWARD
  SHARE_BONUS
  USER_PAY_SENT
  USER_PAY_RECEIVED
}

enum TransactionStatus {
  PENDING
  COMPLETED
  FAILED
  CANCELLED
}

enum WalletType {
  MAIN
  BONUS
  REFERRAL
  LEVEL
  REWARD
  SHARE
}

enum DepositMethod {
  UPI
  BANK_TRANSFER
  QR_CODE
}

enum DepositStatus {
  PENDING
  APPROVED
  REJECTED
}

enum WithdrawalStatus {
  PENDING
  PROCESSING
  APPROVED
  REJECTED
}

enum KYCStatus {
  PENDING
  APPROVED
  REJECTED
}

enum NotificationType {
  INFO
  SUCCESS
  WARNING
  ERROR
}

enum OfflineTaskStatus {
  ASSIGNED
  COMPLETED
  EXPIRED
}

// ============================================================
// SYSTEM SETTINGS MODEL
// ============================================================
model SystemSettings {
  id                      String   @id @default("default")
  referralPercent         Float    @default(10.0)
  level1Percent           Float    @default(10.0)
  level2Percent           Float    @default(5.0)
  level3Percent           Float    @default(2.0)
  levelIncomeEnabled      Boolean  @default(true)
  referralCommissionStructure String @default("10,5,3")
  starPerformerThreshold  Float    @default(5000.0)
  starPerformerEnabled    Boolean  @default(true)
  doubleStarThreshold     Float    @default(25000.0)
  doubleStarEnabled       Boolean  @default(true)
  eliteThreshold          Float    @default(50000.0)
  eliteEnabled            Boolean  @default(true)
  tlRankRequiredReferrals Int      @default(5)
  tlRankRequiredCommission Float   @default(100000.0)
  tlRankMaxUsers          Int      @default(25)
  tlRankEnabled           Boolean  @default(true)
  directorRankRequiredTLs Int      @default(5)
  directorRankMaxUsers    Int      @default(5)
  directorRankEnabled     Boolean  @default(true)
  withdrawalDeductionPercent Float   @default(20.0)
  userPayDeductionPercent    Float   @default(0.0)
  basicDailyYieldPercent     Float   @default(0.2)
  heroMembers             String   @default("25,689+")
  heroActive              String   @default("8,932+")
  heroPaid                String   @default("₹12.45 Cr+")
  heroRate                String   @default("99.8%")
  giftDepositAmount        Float    @default(0)
  createdAt               DateTime @default(now())
  updatedAt               DateTime @updatedAt
}

// ============================================================
// MEMBERSHIP PLAN MODEL
// ============================================================
model MembershipPlan {
  id              String   @id @default(cuid())
  name            String   @unique
  price           Float
  durationDays    Int      // duration in days, e.g. 365, or -1 for lifetime
  depositBonus    Float    @default(0.0) // deposit yield bonus %
  referralLevel1  Float    @default(10.0) // L1 referral commission %
  referralLevel2  Float    @default(0.0)  // L2 referral commission %
  referralLevel3  Float    @default(0.0)  // L3 referral commission %
  withdrawalTime  String   @default("24-48 Hours")
  support         String   @default("Standard Email")
  features        String[] // Features list array
  color           String   @default("#3B82F6") // UI accent hex color
  isActive        Boolean  @default(true)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  // Relation to users on this plan
  users           User[]   @relation("UserMembershipPlan")
  upgradeRequests MembershipUpgradeRequest[] @relation("PlanUpgradeRequests")

  @@index([isActive])
}

// ============================================================
// GIFT MODEL (PREMIUM ONLY)
// ============================================================
model Gift {
  id                   String    @id @default(cuid())
  userId               String
  user                 User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  
  // Gift address details
  fullName             String
  age                  Int
  mobile               String
  email                String
  houseNo              String
  area                 String
  city                 String
  district             String
  state                String
  pinCode              String

  // Tracking details (added by admin)
  trackingNumber       String    @default("")
  courierName          String    @default("")
  dispatchDate         DateTime?
  expectedDeliveryDate DateTime?
  deliveryStatus       String    @default("PENDING") // PENDING, SHIPPED, OUT_FOR_DELIVERY, DELIVERED
  acceptedAt           DateTime?
  remarks              String    @default("")
  
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  @@index([userId])
  @@index([deliveryStatus])
}

// ============================================================
// GIFT DEPOSIT MODEL
// ============================================================
model GiftDeposit {
  id           String            @id @default(cuid())
  userId       String
  amount       Float
  proofUrl     String?           // Uploaded payment screenshot
  utrNumber    String?           // UTR/transaction reference
  status       GiftDepositStatus @default(PENDING)
  remarks      String?
  approvedById String?

  user         User              @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt

  @@index([userId])
  @@index([status])
}

enum GiftDepositStatus {
  PENDING
  APPROVED
  REJECTED
}

// ============================================================
// OFFLINE TASK MODEL
// ============================================================
model OfflineTask {
  id          String            @id @default(cuid())
  userId      String
  title       String
  description String
  dueAt       DateTime
  status      OfflineTaskStatus @default(ASSIGNED)
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([userId])
  @@index([status])
  @@index([dueAt])
}

// ============================================================
// OTP MODEL
// ============================================================
model Otp {
  id        String   @id @default(cuid())
  email     String
  otp       String
  expiresAt DateTime
  verified  Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
}

// ============================================================
// PASSWORD RESET REQUEST MODEL
// ============================================================
model PasswordResetRequest {
  id        String   @id @default(cuid())
  email     String
  status    String   @default("PENDING") // PENDING, RESOLVED
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([email])
  @@index([status])
}

// ============================================================
// TICKETING SYSTEM MODELS
// ============================================================
enum TicketCategory {
  TECHNICAL_ISSUE
  PAYMENT_ISSUE
  FEATURE_REQUEST
  COMPLAINT
  OTHER
}

enum TicketPriority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum TicketStatus {
  OPEN
  IN_PROGRESS
  RESOLVED
  CLOSED
}

model Ticket {
  id          String         @id @default(cuid())
  ticketId    String         @unique
  userId      String
  subject     String
  category    TicketCategory
  priority    TicketPriority
  description String
  attachment  String?
  status      TicketStatus   @default(OPEN)
  createdAt   DateTime       @default(now())
  updatedAt   DateTime       @updatedAt

  user          User                 @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages      TicketMessage[]
  notifications TicketNotification[]

  @@index([userId])
  @@index([status])
  @@index([ticketId])
}

model TicketMessage {
  id         String   @id @default(cuid())
  ticketId   String
  senderId   String
  senderRole String   // "USER" or "ADMIN"
  message    String   @db.Text
  createdAt  DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)

  @@index([ticketId])
  @@index([senderId])
}

model TicketNotification {
  id        String   @id @default(cuid())
  userId    String
  ticketId  String
  title     String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  ticket Ticket @relation(fields: [ticketId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([ticketId])
  @@index([isRead])
}

// ============================================================
// MEMBERSHIP UPGRADE REQUEST MODEL
// ============================================================
model MembershipUpgradeRequest {
  id              String   @id @default(cuid())
  userId          String
  planId          String
  status          String   @default("PENDING") // PENDING, APPROVED, REJECTED
  remarks         String?
  approvedById    String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user            User     @relation("UserUpgradeRequests", fields: [userId], references: [id], onDelete: Cascade)
  plan            MembershipPlan @relation("PlanUpgradeRequests", fields: [planId], references: [id], onDelete: Cascade)
  approvedBy      Admin?   @relation("AdminMembershipUpgradeApproval", fields: [approvedById], references: [id])

  @@index([userId])
  @@index([status])
}

// ============================================================
// USER PAY REQUEST MODEL
// ============================================================
model UserPayRequest {
  id                 String            @id @default(cuid())
  senderId           String
  receiverId         String
  amount             Float             // Entered Amount
  deductionPercent   Float             // Deduction Percentage
  deductionAmount    Float             // Deduction Amount
  finalAmount        Float             // Final Transfer Amount
  status             UserPayStatus     @default(PENDING)
  createdAt          DateTime          @default(now())
  updatedAt          DateTime          @updatedAt

  sender             User              @relation("SenderRequests", fields: [senderId], references: [id], onDelete: Cascade)
  receiver           User              @relation("ReceiverRequests", fields: [receiverId], references: [id], onDelete: Cascade)

  @@index([senderId])
  @@index([receiverId])
  @@index([status])
}

enum UserPayStatus {
  PENDING
  APPROVED
  REJECTED
}
